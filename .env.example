MAILERLITE_GROUP_UPDATES=
MAILERLITE_GROUP_VOLUNTEER=
MAILERLITE_GROUP_SPONSOR=
MAILERLITE_GROUP_EQUIPMENT=

# --- Formspree (volunteer/sponsor/contact forms; newsletter now uses MailerLite) ---
NEXT_PUBLIC_FORMSPREE_CONTACT=
NEXT_PUBLIC_FORMSPREE_VOLUNTEER=
NEXT_PUBLIC_FORMSPREE_SPONSOR=
