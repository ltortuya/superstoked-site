# --- Sanity (projectId + dataset are hardcoded in src/sanity/env.ts; only apiVersion is env-overridable) ---
NEXT_PUBLIC_SANITY_API_VERSION=2025-01-01

# --- Analytics (optional; consent-gated) ---
NEXT_PUBLIC_GA_ID=

# --- MailerLite (server-only secret — never prefix with NEXT_PUBLIC) ---
